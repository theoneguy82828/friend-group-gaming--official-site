<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Friend Group Gaming</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&display=swap');
        
        body {
            font-family: 'Inter', sans-serif;
            background-color: #020617;
            color: #f1f5f9;
        }

        .crt-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.25) 50%), 
                        linear-gradient(90deg, rgba(255, 0, 0, 0.06), rgba(0, 255, 0, 0.02), rgba(0, 0, 255, 0.06));
            background-size: 100% 4px, 3px 100%;
            pointer-events: none;
            z-index: 50;
            opacity: 0.1;
        }

        .tab-content {
            display: none;
        }

        .tab-content.active {
            display: block;
            animation: fadeIn 0.5s ease-out;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .pixel-border {
            border-style: solid;
            border-width: 4px;
        }

        /* Styling for the Google Search Input to match theme */
        .gsc-control-cse {
            background-color: transparent !important;
            border: none !important;
            padding: 0 !important;
        }
        .gsc-search-button-v2 {
            background-color: #06b6d4 !important;
            border-color: #06b6d4 !important;
        }
        .gsc-input-box {
            background-color: #0f172a !important;
            border: 2px solid #334155 !important;
        }
        input.gsc-input {
            color: white !important;
            background: none !important;
        }
    </style>
</head>
<body>
    <div class="crt-overlay"></div>

    <!-- Navigation -->
    <nav class="fixed w-full z-40 bg-slate-950/90 border-b-4 border-purple-600 py-4">
        <div class="max-w-6xl mx-auto px-6 flex justify-between items-center">
            <div class="flex items-center gap-2 cursor-pointer" onclick="showTab('home')">
                <div class="bg-cyan-500 p-1 rounded-sm">
                    <i data-lucide="gamepad-2" class="text-slate-950"></i>
                </div>
                <span class="font-black text-xl tracking-tighter italic">FGG</span>
            </div>

            <!-- Desktop Nav -->
            <div class="hidden md:flex gap-6 items-center">
                <button onclick="showTab('home')" class="nav-link text-sm font-bold tracking-widest text-cyan-400">HOME</button>
                <button onclick="showTab('members')" class="nav-link text-sm font-bold tracking-widest text-slate-400">MEMBERS</button>
                <button onclick="showTab('schedule')" class="nav-link text-sm font-bold tracking-widest text-slate-400">CALENDAR</button>
