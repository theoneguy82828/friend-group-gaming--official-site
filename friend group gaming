        </section>

        <!-- SEARCH TAB -->
        <section id="search" class="tab-content">
            <div class="max-w-4xl mx-auto px-6 py-12">
                <div class="bg-slate-900 pixel-border border-cyan-500 p-8">
                    <h2 class="text-3xl font-black italic mb-6 uppercase flex items-center gap-2">
                        <i data-lucide="search"></i> Channel Search
                    </h2>
                    <p class="text-slate-400 mb-8 text-sm italic">Search for videos, episodes, or group news across the web.</p>
                    
                    <!-- Google Custom Search Code -->
                    <script async src="https://cse.google.com/cse.js?cx=53cc48348fe9d4118"></script>
                    <div class="gcse-search"></div>
                </div>
            </div>
