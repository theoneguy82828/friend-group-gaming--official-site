                <button onclick="showTab('studios')" class="nav-link text-sm font-bold tracking-widest text-slate-400">STUDIOS</button>
                <a href="https://youtube.com/@freindgrouppodcast?si=4rCREbBkc-bpmLko" target="_blank" class="bg-red-600 px-4 py-2 text-xs font-black italic flex items-center gap-2">
                    <i data-lucide="youtube" size="16"></i> SUBSCRIBE
                </a>
            </div>

            <!-- Mobile Toggle -->
            <button class="md:hidden text-cyan-400" onclick="toggleMenu()">
                <i data-lucide="menu" id="menu-icon"></i>
            </button>
        </div>
    </nav>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="hidden fixed inset-0 z-30 bg-slate-950 flex flex-col items-center justify-center gap-8">
        <button onclick="showTab('home')" class="text-3xl font-black text-cyan-400">HOME</button>
        <button onclick="showTab('members')" class="text-3xl font-black text-cyan-400">MEMBERS</button>
        <button onclick="showTab('schedule')" class="text-3xl font-black text-cyan-400">CALENDAR</button>
        <button onclick="showTab('search')" class="text-3xl font-black text-cyan-400">SEARCH</button>
        <button onclick="showTab('business')" class="text-3xl font-black text-cyan-400">BUSINESS</button>
        <button onclick="showTab('studios')" class="text-3xl font-black text-cyan-400">STUDIOS</button>
